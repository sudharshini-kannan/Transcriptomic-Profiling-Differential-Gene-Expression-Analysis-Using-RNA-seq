list.files()
list.files("data")
list.files("data/raw_counts")
list.files("data/metadata")
metadata <- read.csv("data/metadata/metadata.csv",
                     row.names = 1)

head(metadata)
dim(metadata)
colnames(metadata)
counts <- read.table(
  "data/raw_counts/GSE152418_p20047_Study1_RawCounts.txt",
  header = TRUE,
  row.names = 1,
  sep = "\t",
  check.names = FALSE
)

head(counts)
dim(counts)
head(colnames(counts))
head(metadata)
dim(metadata)
rownames(metadata)
all(colnames(counts) %in% rownames(metadata))
all(rownames(metadata) %in% colnames(counts))
colnames(metadata)
head(metadata)
table(metadata$condition)
library(DESeq2)

dds <- DESeqDataSetFromMatrix(
    countData = counts,
    colData = metadata,
    design = ~ condition
)
dds
keep <- rowSums(counts(dds) >= 10) >= 3

dds <- dds[keep,]
dim(dds)
dds <- DESeq(dds)
dds
res <- results(dds)
summary(res)
levels(dds$condition)
resOrdered <- res[order(res$padj), ]

head(resOrdered)
table(dds$condition)
dds$condition <- relevel(dds$condition, ref = "Convalescent")
levels(dds$condition)
dds <- DESeq(dds)
res_COVID <- results(dds, contrast = c("condition", "COVID", "Convalescent"))
summary(res_COVID)
res_COVID_ordered <- res_COVID[order(res_COVID$padj), ]

head(res_COVID_ordered)
up_genes <- subset(res_COVID_ordered,
                   padj < 0.1 & log2FoldChange > 0)

down_genes <- subset(res_COVID_ordered,
                     padj < 0.1 & log2FoldChange < 0)

dim(up_genes)
dim(down_genes)
write.csv(as.data.frame(res_COVID_ordered),
          "result/COVID_vs_Convalescent_DESeq2_results.csv")

write.csv(as.data.frame(up_genes),
          "result/COVID_upregulated_genes.csv")

write.csv(as.data.frame(down_genes),
          "result/COVID_downregulated_genes.csv")
head(res_COVID_ordered)
dim(up_genes)
dim(down_genes)
dim(up_genes)

[1] 261 6
vsd <- vst(dds, blind = FALSE)
library(ggplot2)

pca_data <- plotPCA(vsd,
                    intgroup = "condition",
                    returnData = TRUE)

head(pca_data)
percentVar <- round(100 * attr(pca_data, "percentVar"))
percentVar
ggplot(pca_data,
       aes(x = PC1,
           y = PC2,
           color = condition)) +
  geom_point(size = 4) +
  xlab(paste0("PC1: ", percentVar[1], "% variance")) +
  ylab(paste0("PC2: ", percentVar[2], "% variance")) +
  theme_bw() +
  ggtitle("PCA: COVID vs Convalescent RNA-seq Samples")
library(ggplot2)

volcano_data <- as.data.frame(res_COVID)

volcano_data$gene <- rownames(volcano_data)

volcano_data$significance <- "Not Significant"

volcano_data$significance[
  volcano_data$padj < 0.1 &
  volcano_data$log2FoldChange > 0
] <- "Upregulated"

volcano_data$significance[
  volcano_data$padj < 0.1 &
  volcano_data$log2FoldChange < 0
] <- "Downregulated"
table(volcano_data$significance)
ggplot(volcano_data,
       aes(x = log2FoldChange,
           y = -log10(padj),
           color = significance)) +
  geom_point(alpha = 0.6) +
  theme_bw() +
  xlab("log2 Fold Change (COVID vs Convalescent)") +
  ylab("-log10 Adjusted p-value") +
  ggtitle("Volcano Plot: COVID vs Convalescent")
library(pheatmap)

top_genes <- head(
  rownames(res_COVID_ordered),
  50
)
heatmap_data <- assay(vsd)[top_genes, ]
dim(heatmap_data)
annotation_col <- data.frame(
  Condition = colData(vsd)$condition
)

rownames(annotation_col) <- colnames(vsd)
head(annotation_col)
pheatmap(
  heatmap_data,
  scale = "row",
  annotation_col = annotation_col,
  show_rownames = FALSE,
  cluster_cols = TRUE,
  cluster_rows = TRUE,
  main = "Top 50 Differentially Expressed Genes\nCOVID vs Convalescent"
)
library(org.Hs.eg.db)
if (!requireNamespace("BiocManager", quietly = TRUE))
    install.packages("BiocManager")
BiocManager::install("org.Hs.eg.db")
library(org.Hs.eg.db)
gene_annotation <- AnnotationDbi::select(
  org.Hs.eg.db,
  keys = rownames(res_COVID_ordered),
  columns = c("SYMBOL", "ENTREZID"),
  keytype = "ENSEMBL"
)

head(gene_annotation)
dim(gene_annotation)
sum(!is.na(gene_annotation$SYMBOL))
res_annotated <- merge(
  as.data.frame(res_COVID_ordered),
  gene_annotation,
  by.x = "row.names",
  by.y = "ENSEMBL"
)

head(res_annotated)
dim(res_annotated)
res_annotated <- res_annotated[order(res_annotated$padj), ]

head(res_annotated)
significant_DEGs <- subset(
  res_annotated,
  padj < 0.1
)

dim(significant_DEGs)
entrez_genes <- significant_DEGs$ENTREZID
entrez_genes <- entrez_genes[!is.na(entrez_genes)]
length(entrez_genes)
library(clusterProfiler)
library(enrichplot)
length(entrez_genes)
ego <- enrichGO(
  gene          = entrez_genes,
  OrgDb         = org.Hs.eg.db,
  keyType       = "ENTREZID",
  ont           = "BP",
  pAdjustMethod = "BH",
  pvalueCutoff  = 0.05,
  qvalueCutoff  = 0.1,
  readable      = TRUE
)
head(ego)
dim(ego)
dotplot(
  ego,
  showCategory = 15,
  title = "GO Biological Process Enrichment\nCOVID vs Convalescent"
)
write.csv(
  as.data.frame(ego),
  "result/GO_Biological_Process_COVID_vs_Convalescent.csv",
  row.names = FALSE
)
library(clusterProfiler)

kegg <- enrichKEGG(
  gene = entrez_genes,
  organism = "hsa",
  pvalueCutoff = 0.05
)
head(kegg)
dim(kegg)
dotplot(
  kegg,
  showCategory = 7,
  title = "KEGG Pathway Enrichment\nCOVID vs Convalescent"
)
write.csv(
  as.data.frame(kegg),
  "result/KEGG_Pathway_COVID_vs_Convalescent.csv",
  row.names = FALSE
)
q()
